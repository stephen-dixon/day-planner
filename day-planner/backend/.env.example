APP_ENV=production
LOG_LEVEL=INFO
SECRET_KEY=replace-with-a-long-random-value

# Keep production SQLite outside the repo.
DATABASE_URL=sqlite:////var/lib/dayplanner/dayplanner.db
CATALOG_DIR=/var/lib/dayplanner/catalogs

# Dev CORS. Production behind Caddy same-origin usually does not need CORS.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

FRONTEND_URL=http://127.0.0.1:5173
APP_TIMEZONE=Europe/London
OAUTH_STATE_SECRET=replace-with-a-long-random-value
CATALOG_TOKEN_SECRET=replace-with-a-long-random-value

LLM_PROVIDER=openai
LLM_MODEL=gpt-5.5-mini
LLM_API_KEY=
LLM_BASE_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=
MICROSOFT_TENANT=common

GITHUB_TOKEN=
GITHUB_DEFAULT_OWNER=
GITHUB_DEFAULT_REPO=
